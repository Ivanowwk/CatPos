generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id             String   @id @default(cuid())

  name           String

  costPrice      Float

  profitMargin   Float

  salePrice      Float

  stock          Int

  barcode        String?

  category       String?

  createdAt      DateTime @default(now())
}